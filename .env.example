# -----------------------------------------------------------------------------
# ACE OF PACE — PRZYKŁADOWY PLIK KONFIGURACYJNY (.env.example)
# Skopiuj ten plik jako `.env` w katalogu głównym i uzupełnij własne klucze.
# Plik `.env` jest ignorowany przez Gita ze względów bezpieczeństwa.
# -----------------------------------------------------------------------------

# Adresy URL aplikacji (domyślne dla dewelopmentu)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# OpenRouteService API Key (opcjonalny, używany w legacy routing)
VITE_ORS_API_KEY=YOUR_ORS_API_KEY_HERE

# GOOGLE OAUTH (Weryfikacja logowania)
# Uzyskaj w Google Cloud Console -> Credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# STRAVA INTEGRATION (Pobieranie treningów i tras)
# Uzyskaj w Strava Dashboard -> My API Application
STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=YOUR_STRAVA_CLIENT_SECRET

# GOOGLE GEMINI API KEY (Kasia AI Running Coach)
# Uzyskaj w Google AI Studio (https://aistudio.google.com/)
# Jeśli nie podasz klucza, Kasia będzie działać w uproszczonym trybie offline.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
