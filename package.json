{
  "name": "smart-loop-mapper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "restart": "pkill -f 'python main.py' 2>/dev/null; pkill -f 'vite' 2>/dev/null; sleep 1; (cd backend && source venv/bin/activate && python main.py &); npm run dev"
  },
